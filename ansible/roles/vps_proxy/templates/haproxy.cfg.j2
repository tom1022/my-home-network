# XRay backend (TCP passthrough to k3s nodes)
backend bk_xray
    mode tcp
    balance leastconn
{# Prefer using inventory group 'k3s' and hostvars. Fallback to k3s_internal_ips, then to vps_proxy_tcp_upstreams. #}
{% if groups['k3s'] is defined and groups['k3s'] | length > 0 %}
{% for h in groups['k3s'] %}
{% set _ip = hostvars[h].ansible_host | default(hostvars[h].inventory_hostname) %}
    server xray_{{ loop.index }} {{ _ip }}:{{ vps_proxy_backend_port | default(32080) }} check inter 10s
{% endfor %}
{% elif k3s_internal_ips is defined and k3s_internal_ips | length > 0 %}
{% for ip in k3s_internal_ips.values() %}
    server xray_{{ loop.index }} {{ ip }}:{{ vps_proxy_backend_port | default(32080) }} check inter 10s
{% endfor %}
{% else %}
# No k3s inventory group or internal IPs defined; configure backend members via `vps_proxy_tcp_upstreams` if provided
{% if vps_proxy_tcp_upstreams is defined %}
    {% for u in vps_proxy_tcp_upstreams %}
        {% if u.name == 'xray_vpn_backend' and u.members is defined %}
            {% for m in u.members %}
    server xray_cfg_{{ loop.index }} {{ m.host }}:{{ m.port }} check inter 10s
            {% endfor %}
        {% endif %}
    {% endfor %}
{% endif %}
{% endif %}

# Default web passthrough backend -> local nginx on loopback
backend bk_web
    mode tcp
    balance roundrobin
    server web_local 127.0.0.1:8443 check inter 10s
